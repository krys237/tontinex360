# =============================================================================
# Node.js / Next.js (frontend)
# =============================================================================
**/node_modules/
**/.next/
**/out/
**/.turbo/
**/.swc/
**/.cache/
**/.pnp.*

# Dépendances
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml
# (commenter les lignes ci-dessus si tu veux garder les lockfiles)

# Build artifacts
**/build/
**/dist/

# Env files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
# Ne pas ignorer les exemples
!**/.env.example

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# =============================================================================
# Python / Django (backend)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
eggs/
.eggs/

# Virtual env
venv/
.venv/
env/
.env

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
**/media/
**/staticfiles/
*.mo
*.pot
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid

# Coverage
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/

# =============================================================================
# IDE / Éditeurs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Archives & misc
# =============================================================================
*.zip
*.tar.gz
*.7z
